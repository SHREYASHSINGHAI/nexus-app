{
  "version": 2,
  "functions": {
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/share.js": {
      "maxDuration": 30
    },
    "api/config.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/chat",   "dest": "/api/chat.js"   },
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/api/share",  "dest": "/api/share.js"  },
    { "src": "/(.*)",       "dest": "/index.html"    }
  ]
}
