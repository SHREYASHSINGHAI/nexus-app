{
  "version": 2,
  "builds": [
    { "src": "api/chat.js",   "use": "@vercel/node" },
    { "src": "api/config.js", "use": "@vercel/node" },
    { "src": "api/share.js",  "use": "@vercel/node" },
    { "src": "api/create-order.js", "use": "@vercel/node" },
    { "src": "api/verify-payment.js", "use": "@vercel/node" },
    { "src": "index.html",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat",   "dest": "/api/chat.js"   },
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/api/share",  "dest": "/api/share.js"  },
    { "src": "/api/create-order", "dest": "/api/create-order.js" },
    { "src": "/api/verify-payment", "dest": "/api/verify-payment.js" },
    { "src": "/(.*)",       "dest": "/index.html"    }
  ]
}
